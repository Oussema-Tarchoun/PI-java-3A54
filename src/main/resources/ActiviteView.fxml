<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ActiviteController"
      stylesheets="@css/dark-theme.css"
      style="-fx-background-color: #0f1a14;">
    <VBox styleClass="sidebar">
        <Label text="AIVA" styleClass="sidebar-logo"/>
        <Label text="MENU PRINCIPAL" styleClass="sidebar-section-label"/>
        <Button text="Tableau de bord" styleClass="sidebar-btn"/>
        <Label text="SPORTS" styleClass="sidebar-section-label"/>
        <Button text="Activites" styleClass="sidebar-btn sidebar-btn-active"/>
        <Button text="Objectifs" styleClass="sidebar-btn" onAction="#showObjectifs"/>
        <Label text="FINANCE" styleClass="sidebar-section-label"/>
        <Button text="Depenses" styleClass="sidebar-btn"/>
        <Button text="Categories" styleClass="sidebar-btn"/>
        <Label text="ENERGIES" styleClass="sidebar-section-label"/>
        <Button text="Consommation" styleClass="sidebar-btn"/>
        <Button text="Recommandations" styleClass="sidebar-btn"/>
    </VBox>
    <VBox styleClass="main-content" HBox.hgrow="ALWAYS" spacing="20">
        <VBox spacing="4">
            <Label text="Activites" styleClass="page-title"/>
            <Label text="Dashboard / Activites" styleClass="breadcrumb"/>
        </VBox>
        <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="16">
            <HBox alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS" spacing="4">
                    <Label text="Toutes les activites" styleClass="card-title"/>
                    <Label text="Liste des activites physiques par objectif" styleClass="card-subtitle"/>
                </VBox>
                <Button text="+ Nouvelle activite" styleClass="btn-primary" onAction="#ouvrirFormulaire"/>
            </HBox>
            <!-- Barre de filtre / tri -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="dureeMinField" promptText="Duree min (min)" prefWidth="140"/>
                <TextField fx:id="dureeMaxField" promptText="Duree max (min)" prefWidth="140"/>
                <Button text="Filtrer"       styleClass="btn-primary" onAction="#filtrer"/>
                <Button text="Reinitialiser" styleClass="btn-primary" onAction="#charger"/>
                <Button text="Date"          styleClass="btn-primary" onAction="#trierDate"/>
                <Button text="Calories"      styleClass="btn-primary" onAction="#trierCalories"/>
            </HBox>
            <VBox fx:id="formPane" spacing="10" managed="false" visible="false"
                  style="-fx-background-color: #1a2d20; -fx-background-radius: 8px; -fx-padding: 16px;">
                <HBox spacing="10">
                    <TextField fx:id="typeField"      promptText="Type"           prefWidth="140"/>
                    <TextField fx:id="dureeField"     promptText="Duree (min)"    prefWidth="110"/>
                    <TextField fx:id="caloriesField"  promptText="Calories"       prefWidth="110"/>
                    <TextField fx:id="intensiteField" promptText="Intensite"      prefWidth="120"/>
                    <DatePicker fx:id="datePicker"    prefWidth="150"/>
                    <ComboBox  fx:id="objectifCombo"  promptText="Objectif"       prefWidth="180" HBox.hgrow="ALWAYS"/>
                </HBox>
                <!-- Boutons mode Ajout -->
                <HBox fx:id="btnAjouterBox" spacing="8">
                    <Button text="Enregistrer" styleClass="btn-success"
                            prefWidth="120" minWidth="120" maxWidth="120"
                            onAction="#ajouter"/>
                    <Button text="Annuler" styleClass="btn-primary"
                            prefWidth="120" minWidth="120" maxWidth="120"
                            onAction="#annuler"/>
                </HBox>
                <!-- Boutons mode Edition -->
                <HBox fx:id="btnModifierBox" spacing="8" managed="false" visible="false">
                    <Button text="Modifier" styleClass="btn-warning"
                            prefWidth="120" minWidth="120" maxWidth="120"
                            onAction="#modifier"/>
                    <Button text="Annuler" styleClass="btn-primary"
                            prefWidth="120" minWidth="120" maxWidth="120"
                            onAction="#annuler"/>
                </HBox>
                <Label fx:id="msgLabel" styleClass="msg-label"/>
            </VBox>
            <TableView fx:id="table" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: transparent;">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colId"        text="#"          prefWidth="40"  minWidth="40"  maxWidth="40"/>
                    <TableColumn fx:id="colType"      text="TYPE"       prefWidth="110" minWidth="90"/>
                    <TableColumn fx:id="colDuree"     text="DUREE"      prefWidth="70"  minWidth="60"/>
                    <TableColumn fx:id="colCalories"  text="CALORIES"   prefWidth="80"  minWidth="70"/>
                    <TableColumn fx:id="colDate"      text="DATE"       prefWidth="100" minWidth="90"/>
                    <TableColumn fx:id="colIntensite" text="INTENSITE"  prefWidth="90"  minWidth="80"/>
                    <TableColumn fx:id="colObjectif"  text="OBJECTIF"   prefWidth="80"  minWidth="70"/>
                    <TableColumn fx:id="colActions"   text="ACTIONS"    prefWidth="170" minWidth="170"/>
                </columns>
                <placeholder>
                    <Label text="Aucune activite trouvee"
                           style="-fx-text-fill: #5a7a65;"/>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>
</HBox>
