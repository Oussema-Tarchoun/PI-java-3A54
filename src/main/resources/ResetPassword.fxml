<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefWidth="1080.0" prefHeight="680.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.ResetPasswordController"
            stylesheets="@styles.css">
    <!-- Background -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
          styleClass="main-window"/>

    <!-- Left side (Text/Logo) -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" prefWidth="440"
          alignment="CENTER" spacing="24">
        <VBox alignment="CENTER" spacing="10">
             <VBox alignment="CENTER" styleClass="logo-box" prefWidth="80" prefHeight="80" maxWidth="80" maxHeight="80">
                <Label text="A" style="-fx-font-size: 40px; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </VBox>
            <Label text="AIVA" styleClass="page-title" style="-fx-font-size: 36px;"/>
            <Label text="RECOVERY" styleClass="stat-label"/>
        </VBox>
        <Label text="Récupérez l'accès à votre compte en quelques étapes simples." styleClass="card-subtitle"
               wrapText="true" textAlignment="CENTER" maxWidth="300"/>
    </VBox>

    <!-- Right form panel -->
    <VBox alignment="CENTER" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="440" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <VBox maxWidth="480" spacing="0" styleClass="glass-card">
            <VBox spacing="28" style="-fx-padding: 10;">

            <VBox spacing="6">
                <Label text="Réinitialisation" styleClass="card-title" style="-fx-font-size: 24px;"/>
                <Label fx:id="lblSubtitle" text="Récupérez l'accès à votre compte administrateur." styleClass="card-subtitle" wrapText="true"/>
            </VBox>

            <!-- STEP 1: Enter Email -->
            <VBox fx:id="step1Email" spacing="20">
                <VBox spacing="2">
                    <Label fx:id="errEmail" text="" visible="false" managed="false" style="-fx-text-fill: #ff6b6b; -fx-font-size: 11px;"/>
                    <Label text="ADRESSE EMAIL" styleClass="form-label"/>
                    <TextField fx:id="tfEmail" promptText="votre@email.com" styleClass="form-input"/>
                </VBox>
                <Button text="Recevoir le code &#8594;" styleClass="btn-primary" maxWidth="Infinity" prefHeight="44" onAction="#handleSendCode"/>
            </VBox>
 
            <!-- STEP 2: Enter Code and New Password -->
            <VBox fx:id="step2Reset" spacing="16" visible="false" managed="false">
                <VBox spacing="2">
                    <Label fx:id="errToken" text="" visible="false" managed="false" style="-fx-text-fill: #ff6b6b; -fx-font-size: 11px;"/>
                    <Label text="CODE DE VALIDATION" styleClass="form-label"/>
                    <TextField fx:id="tfToken" promptText="000000" styleClass="form-input"/>
                </VBox>
                <VBox spacing="2">
                    <Label fx:id="errNewPassword" text="" visible="false" managed="false" style="-fx-text-fill: #ff6b6b; -fx-font-size: 11px;"/>
                    <Label text="NOUVEAU MOT DE PASSE" styleClass="form-label"/>
                    <PasswordField fx:id="pfNewPassword" promptText="••••••••" styleClass="form-input"/>
                </VBox>
                <VBox spacing="2">
                    <Label fx:id="errConfirmPassword" text="" visible="false" managed="false" style="-fx-text-fill: #ff6b6b; -fx-font-size: 11px;"/>
                    <Label text="CONFIRMER LE MOT DE PASSE" styleClass="form-label"/>
                    <PasswordField fx:id="pfConfirmPassword" promptText="••••••••" styleClass="form-input"/>
                </VBox>
                <Button text="Changer le mot de passe" styleClass="btn-primary" maxWidth="Infinity" prefHeight="44" onAction="#handleReset"/>
            </VBox>

            <!-- Feedback labels -->
            <VBox spacing="4">
                <Label fx:id="lblError" text="" styleClass="error-label" wrapText="true" managed="false" visible="false"/>
                <Label fx:id="lblSuccess" text="" style=" -fx-text-fill: #22c55e; -fx-font-size: 12px;" wrapText="true" managed="false" visible="false"/>
            </VBox>

            <!-- Back to login -->
            <HBox alignment="CENTER" spacing="8" style="-fx-padding: 20 0 0 0;">
                <Button text="&#8592; Retour à la connexion" styleClass="btn-secondary" onAction="#goToLogin"/>
            </HBox>
            </VBox>
        </VBox>
    </VBox>
</AnchorPane>
