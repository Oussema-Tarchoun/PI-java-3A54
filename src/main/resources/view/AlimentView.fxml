<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    Controller : Controllers.aliment.AlimentFrontController
    Place at   : src/main/resources/views/AlimentView.fxml
    Loads inside MainController contentArea (StackPane)
-->
<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.aliment.AlimentFrontController"
            fitToWidth="true"
            style="-fx-background: transparent; -fx-background-color: transparent;">

    <VBox spacing="24" style="-fx-background-color: #0a0e1a; -fx-padding: 8 0 32 0;">

        <!-- ══════════════════════════════════════
             HEADER
        ══════════════════════════════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Mes Aliments"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                <Label text="Gérez votre bibliothèque d'aliments et leurs valeurs nutritionnelles"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
            </VBox>
            <Button text="➕ Nouvel Aliment"
                    onAction="#openAddForm"
                    style="-fx-background-color: #10b981; -fx-text-fill: #ffffff;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
        </HBox>

        <!-- ══════════════════════════════════════
             STAT CARDS
        ══════════════════════════════════════ -->
        <HBox spacing="16">
            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane style="-fx-background-color: rgba(0,212,255,0.15);
                                     -fx-background-radius: 10;
                                     -fx-min-width: 40; -fx-min-height: 40;
                                     -fx-max-width: 40; -fx-max-height: 40;">
                        <Label text="🥗" style="-fx-font-size: 18px;"/>
                    </StackPane>
                    <Label text="TOTAL" styleClass="card-subtitle"/>
                </HBox>
                <Label fx:id="statTotal" text="—"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                <Label text="aliments" styleClass="card-subtitle"/>
            </VBox>

            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane style="-fx-background-color: rgba(245,158,11,0.15);
                                     -fx-background-radius: 10;
                                     -fx-min-width: 40; -fx-min-height: 40;
                                     -fx-max-width: 40; -fx-max-height: 40;">
                        <Label text="🔥" style="-fx-font-size: 18px;"/>
                    </StackPane>
                    <Label text="MOY. CALORIES" styleClass="card-subtitle"/>
                </HBox>
                <Label fx:id="statAvgCal" text="—"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                <Label text="pour 100g" styleClass="card-subtitle"/>
            </VBox>

            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane style="-fx-background-color: rgba(239,68,68,0.15);
                                     -fx-background-radius: 10;
                                     -fx-min-width: 40; -fx-min-height: 40;
                                     -fx-max-width: 40; -fx-max-height: 40;">
                        <Label text="🏆" style="-fx-font-size: 18px;"/>
                    </StackPane>
                    <Label text="PLUS CALORIQUE" styleClass="card-subtitle"/>
                </HBox>
                <Label fx:id="statMaxCal" text="—"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                <Label text="calories max" styleClass="card-subtitle"/>
            </VBox>

            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane style="-fx-background-color: rgba(139,92,246,0.15);
                                     -fx-background-radius: 10;
                                     -fx-min-width: 40; -fx-min-height: 40;
                                     -fx-max-width: 40; -fx-max-height: 40;">
                        <Label text="📊" style="-fx-font-size: 18px;"/>
                    </StackPane>
                    <Label text="AVEC MACROS" styleClass="card-subtitle"/>
                </HBox>
                <Label fx:id="statWithMacro" text="—"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                <Label text="macros renseignées" styleClass="card-subtitle"/>
            </VBox>
        </HBox>

        <!-- ══════════════════════════════════════
             SEARCH
        ══════════════════════════════════════ -->
        <TextField fx:id="searchField"
                   promptText="🔍 Rechercher un aliment..."
                   onKeyReleased="#handleSearch"
                   style="-fx-background-color: #161b2e; -fx-text-fill: #ffffff;
                          -fx-prompt-text-fill: #64748b;
                          -fx-background-radius: 8; -fx-border-radius: 8;
                          -fx-border-color: #2a3142; -fx-border-width: 1;
                          -fx-padding: 10 16 10 16; -fx-font-size: 13px;"/>

        <!-- ══════════════════════════════════════
             ADD / EDIT FORM PANEL
        ══════════════════════════════════════ -->
        <VBox fx:id="formPanel" styleClass="card" spacing="18"
              visible="false" managed="false">

            <Label fx:id="formTitle" text="Nouvel Aliment"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>

            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="NOM DE L'ALIMENT" styleClass="form-label"/>
                    <TextField fx:id="nomField" promptText="Ex: Tomate"
                               style="-fx-background-color: #0a0e1a; -fx-text-fill: #ffffff;
                                      -fx-background-radius: 8; -fx-border-radius: 8;
                                      -fx-border-color: #2a3142; -fx-border-width: 1;
                                      -fx-padding: 10 16 10 16;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="QUANTITÉ (G)" styleClass="form-label"/>
                    <TextField fx:id="quantiteField" promptText="100"
                               style="-fx-background-color: #0a0e1a; -fx-text-fill: #ffffff;
                                      -fx-background-radius: 8; -fx-border-radius: 8;
                                      -fx-border-color: #2a3142; -fx-border-width: 1;
                                      -fx-padding: 10 16 10 16;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="CALORIES (KCAL)" styleClass="form-label"/>
                    <TextField fx:id="caloriesField" promptText="Auto-calculé"
                               style="-fx-background-color: #0a0e1a; -fx-text-fill: #ffffff;
                                      -fx-background-radius: 8; -fx-border-radius: 8;
                                      -fx-border-color: #2a3142; -fx-border-width: 1;
                                      -fx-padding: 10 16 10 16;"/>
                </VBox>
            </HBox>

            <!-- Macros section -->
            <VBox spacing="10"
                  style="-fx-background-color: rgba(139,92,246,0.08);
                         -fx-background-radius: 10; -fx-padding: 16;
                         -fx-border-color: rgba(139,92,246,0.2); -fx-border-radius: 10; -fx-border-width: 1;">
                <Label text="Macronutriments"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>
                <Label text="Valeurs pour la quantité indiquée"
                       style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="PROTÉINES (G)"
                               style="-fx-text-fill: #10b981; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <TextField fx:id="proteinesField" promptText="0"
                                   style="-fx-background-color: #0a0e1a; -fx-text-fill: #ffffff;
                                          -fx-background-radius: 8; -fx-border-radius: 8;
                                          -fx-border-color: rgba(16,185,129,0.4); -fx-border-width: 1;
                                          -fx-padding: 10 16 10 16;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="GLUCIDES (G)"
                               style="-fx-text-fill: #f59e0b; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <TextField fx:id="glucidesField" promptText="0"
                                   style="-fx-background-color: #0a0e1a; -fx-text-fill: #ffffff;
                                          -fx-background-radius: 8; -fx-border-radius: 8;
                                          -fx-border-color: rgba(245,158,11,0.4); -fx-border-width: 1;
                                          -fx-padding: 10 16 10 16;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="LIPIDES (G)"
                               style="-fx-text-fill: #8b5cf6; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <TextField fx:id="lipidesField" promptText="0"
                                   style="-fx-background-color: #0a0e1a; -fx-text-fill: #ffffff;
                                          -fx-background-radius: 8; -fx-border-radius: 8;
                                          -fx-border-color: rgba(139,92,246,0.4); -fx-border-width: 1;
                                          -fx-padding: 10 16 10 16;"/>
                    </VBox>
                </HBox>
            </VBox>

            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: #ef4444; -fx-font-size: 13px;"
                   wrapText="true" visible="false" managed="false"/>

            <HBox spacing="12">
                <Button text="✔  Enregistrer" onAction="#handleSave"
                        style="-fx-background-color: #10b981; -fx-text-fill: #ffffff;
                               -fx-font-weight: bold; -fx-background-radius: 8;
                               -fx-padding: 10 24 10 24; -fx-cursor: hand;"/>
                <Button text="Annuler" onAction="#handleCancel"
                        style="-fx-background-color: #2a3142; -fx-text-fill: #94a3b8;
                               -fx-background-radius: 8; -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- ══════════════════════════════════════
             ALIMENT CARDS GRID
        ══════════════════════════════════════ -->
        <FlowPane fx:id="cardsPane" hgap="16" vgap="16"
                  style="-fx-padding: 4 0 0 0;"/>

    </VBox>
</ScrollPane>
