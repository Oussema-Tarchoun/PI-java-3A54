<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<!--
    Controller : Controllers.repas.RepasController
    CSS        : /style.css  (resources root)
    Logo       : /images/img.png
    Place at   : src/main/resources/view/repas/ListRepas.fxml
-->
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="rootBorderPane"
            fx:controller="Controllers.repas.RepasController"
            styleClass="main-window"
            stylesheets="@/style.css"
            prefWidth="1280" prefHeight="800">

    <!-- ════════════════════════════════════════
         SIDEBAR
    ════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" prefWidth="240" spacing="0">

            <!-- Logo row -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 2 0 16 0;
                         -fx-border-color: rgba(255,255,255,0.08);
                         -fx-border-width: 0 0 1 0;">
                <ImageView fitWidth="36" fitHeight="36" preserveRatio="true" styleClass="logo-image">
                    <Image url="@/images/img.png"/>
                </ImageView>
                <Label text="AIVA" styleClass="logo-name"/>
            </HBox>

            <VBox spacing="1" style="-fx-padding: 12 0 0 0;" VBox.vgrow="ALWAYS">

                <!-- MENU PRINCIPAL -->
                <Label text="MENU PRINCIPAL" styleClass="nav-section-title"/>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToDashboard">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="⊞" styleClass="nav-icon-label nav-icon-muted"/>
                            <Label text="Tableau de bord" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>

                <Button text="&#128203;  Global Reports" maxWidth="Infinity" styleClass="nav-item active"
                        onAction="#goToGlobalReports" id="btnReportsNavList"/>

                <Button text="&#128100;  User Management" maxWidth="Infinity" styleClass="nav-item"
                        onAction="#openUserManagement" id="btnUsersNavList"/>

                <!-- SPORTS -->
                <Label text="SPORTS" styleClass="nav-section-title"/>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToActivites">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="⚡" styleClass="nav-icon-label nav-icon-gold"/>
                            <Label text="Activités" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToObjectifs">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="◎" styleClass="nav-icon-label nav-icon-muted"/>
                            <Label text="Objectifs" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>

                <!-- FINANCE -->
                <Label text="FINANCE" styleClass="nav-section-title"/>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToDepenses">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="▤" styleClass="nav-icon-label nav-icon-muted"/>
                            <Label text="Dépenses" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToCategories">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="⊞" styleClass="nav-icon-label nav-icon-muted"/>
                            <Label text="Catégories" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>

                <!-- ÉNERGIES -->
                <Label text="ÉNERGIES" styleClass="nav-section-title"/>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToEnergie">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="⚡" styleClass="nav-icon-label nav-icon-coral"/>
                            <Label text="Consommation" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToReco">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="◉" styleClass="nav-icon-label nav-icon-muted"/>
                            <Label text="Recommandations" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToStats">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="▲" styleClass="nav-icon-label nav-icon-muted"/>
                            <Label text="Statistiques" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>

                <!-- ALIMENTATION -->
                <Label text="ALIMENTATION" styleClass="nav-section-title"/>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToAliments">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="○" styleClass="nav-icon-label nav-icon-emerald"/>
                            <Label text="Aliments" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>
                <!-- ACTIVE ITEM -->
                <Button styleClass="nav-item active" maxWidth="Infinity" onAction="#goToRepas">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="✦" styleClass="nav-icon-label nav-icon-emerald"/>
                            <Label text="Repas" style="-fx-text-fill: #f5f5f4; -fx-font-weight: bold;"/>
                        </HBox>
                    </graphic>
                </Button>

                <!-- FORMATION -->
                <Label text="FORMATION" styleClass="nav-section-title"/>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToCours">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="□" styleClass="nav-icon-label nav-icon-muted"/>
                            <Label text="Cours" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToChapitres">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="☰" styleClass="nav-icon-label nav-icon-muted"/>
                            <Label text="Chapitres" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>

                <!-- COMPTE -->
                <Label text="COMPTE" styleClass="nav-section-title"/>
                <Button styleClass="nav-item" maxWidth="Infinity" onAction="#goToProfil">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="◯" styleClass="nav-icon-label nav-icon-muted"/>
                            <Label text="Profil" style="-fx-text-fill: inherit;"/>
                        </HBox>
                    </graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- User footer -->
            <HBox styleClass="sidebar-footer" spacing="12" alignment="CENTER_LEFT">
                <StackPane styleClass="user-avatar">
                    <Label text="A" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Admin User"     styleClass="user-name"/>
                    <Label text="Administrateur" styleClass="user-role"/>
                </VBox>
            </HBox>

        </VBox>
    </left>

    <!-- ════════════════════════════════════════
         MAIN CONTENT
    ════════════════════════════════════════ -->
    <center>
        <VBox fx:id="mainContentArea" spacing="0" VBox.vgrow="ALWAYS">

            <!-- TOP NAVBAR -->
            <HBox styleClass="top-navbar" alignment="CENTER_LEFT" spacing="16">
                <Label text="✦" style="-fx-text-fill: #34d399; -fx-font-size: 20px;"/>
                <Label text="Mes Repas" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField"
                           promptText="Rechercher un repas..."
                           styleClass="search-field"
                           onKeyReleased="#handleSearch"/>
                <Button text="+ Nouveau Repas"
                        styleClass="btn-primary"
                        onAction="#openAddRepas"/>
            </HBox>

            <!-- CONTENT -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent;
                               -fx-background: transparent;
                               -fx-border-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 24;">

                    <!-- STAT CARDS -->
                    <HBox spacing="16">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6" minWidth="0">
                            <HBox alignment="TOP_RIGHT">
                                <StackPane styleClass="stat-icon-cyan">
                                    <Label text="✦" style="-fx-text-fill: #34d399; -fx-font-size: 20px;"/>
                                </StackPane>
                            </HBox>
                            <Label text="TOTAL REPAS" styleClass="stat-label"/>
                            <Label fx:id="statTotalRepas" text="—" styleClass="stat-value"/>
                            <Label text="repas enregistrés"
                                   style="-fx-text-fill: rgba(245,245,244,0.40); -fx-font-size: 11px;"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6" minWidth="0">
                            <HBox alignment="TOP_RIGHT">
                                <StackPane styleClass="stat-icon-gold">
                                    <Label text="◉" style="-fx-text-fill: #d4a574; -fx-font-size: 20px;"/>
                                </StackPane>
                            </HBox>
                            <Label text="MOY. CALORIES" styleClass="stat-label"/>
                            <Label fx:id="statAvgCalories" text="—" styleClass="stat-value"/>
                            <Label text="par repas"
                                   style="-fx-text-fill: rgba(245,245,244,0.40); -fx-font-size: 11px;"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6" minWidth="0">
                            <HBox alignment="TOP_RIGHT">
                                <StackPane styleClass="stat-icon-coral">
                                    <Label text="○" style="-fx-text-fill: #e07a5f; -fx-font-size: 20px;"/>
                                </StackPane>
                            </HBox>
                            <Label text="CE MOIS" styleClass="stat-label"/>
                            <Label fx:id="statCeMois" text="—" styleClass="stat-value"/>
                            <Label text="ce mois-ci"
                                   style="-fx-text-fill: rgba(245,245,244,0.40); -fx-font-size: 11px;"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6" minWidth="0">
                            <HBox alignment="TOP_RIGHT">
                                <StackPane styleClass="stat-icon-info">
                                    <Label text="✔" style="-fx-text-fill: #0ea5e9; -fx-font-size: 20px;"/>
                                </StackPane>
                            </HBox>
                            <Label text="SCORE MOY." styleClass="stat-label"/>
                            <Label fx:id="statScore" text="—" styleClass="stat-value"/>
                            <Label text="qualité nutritionnelle"
                                   style="-fx-text-fill: rgba(245,245,244,0.40); -fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>

                    <!-- TABLE CARD -->
                    <VBox styleClass="glass-card" spacing="16" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3">
                                <Label text="Liste des repas" styleClass="card-title"/>
                                <Label fx:id="repasCountLabel" text="0 repas au total"
                                       styleClass="card-subtitle"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="↑ Calories" styleClass="btn-secondary"
                                    onAction="#sortAscCalories"
                                    style="-fx-font-size: 12px; -fx-padding: 7 14 7 14;"/>
                            <Button text="↓ Calories" styleClass="btn-secondary"
                                    onAction="#sortDescCalories"
                                    style="-fx-font-size: 12px; -fx-padding: 7 14 7 14;"/>
                        </HBox>

                        <TableView fx:id="repasTable"
                                   styleClass="table-view"
                                   VBox.vgrow="ALWAYS"
                                   prefHeight="440">
                            <columns>
                                <TableColumn fx:id="colId"       text="#"        prefWidth="55"/>
                                <TableColumn fx:id="colNom"      text="NOM"      prefWidth="220"/>
                                <TableColumn fx:id="colType"     text="TYPE"     prefWidth="130"/>
                                <TableColumn fx:id="colDate"     text="DATE"     prefWidth="120"/>
                                <TableColumn fx:id="colHeure"    text="HEURE"    prefWidth="100"/>
                                <TableColumn fx:id="colCalories" text="CALORIES" prefWidth="115"/>
                                <TableColumn fx:id="colScore"    text="SCORE"    prefWidth="100"/>
                                <TableColumn fx:id="colActions"  text="ACTIONS"  prefWidth="110"/>
                                <TableColumn fx:id="colPdf" text="PDF" prefWidth="70"/>
                            </columns>
                            <placeholder>
                                <Label text="Aucun repas trouvé."
                                       style="-fx-text-fill: rgba(245,245,244,0.35); -fx-font-size: 14px;"/>
                            </placeholder>
                        </TableView>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
