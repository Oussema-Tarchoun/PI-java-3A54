<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.MainControllerFront"
            styleClass="main-window"
            stylesheets="@/styleFront.css"
            prefWidth="1400" prefHeight="900">

    <!-- ════════════════════════════════════════
         TOP NAVBAR (Horizontal)
    ════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30" styleClass="top-navbar" prefHeight="80" style="-fx-padding: 0 40;">
            <!-- Logo area -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <ImageView fitWidth="32" fitHeight="32" preserveRatio="true">
                    <Image url="@/images/img.png"/>
                </ImageView>
                <Label text="AIVA" styleClass="logo-name" style="-fx-font-size: 24px;"/>
            </HBox>

            <!-- Navigation Links -->
            <HBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                <Button fx:id="btnDashboard" styleClass="nav-item" text="Dashboard" onAction="#openDashboard">
                    <graphic><Label text="⊞" styleClass="nav-icon-label"/></graphic>
                </Button>
                <Button fx:id="btnEnergie" styleClass="nav-item" text="Consommation" onAction="#openEnergie">
                    <graphic><Label text="⚡" styleClass="nav-icon-label"/></graphic>
                </Button>
                <Button fx:id="btnRecommandations" styleClass="nav-item" text="Conseils" onAction="#openRecommandations">
                    <graphic><Label text="💡" styleClass="nav-icon-label"/></graphic>
                </Button>
            </HBox>

            <!-- User Profile & Logout -->
            <HBox alignment="CENTER_RIGHT" spacing="20">
                <HBox spacing="10" alignment="CENTER">
                    <Label fx:id="topbarUser" text="Utilisateur" styleClass="user-name"/>
                    <StackPane styleClass="user-avatar" prefWidth="35" prefHeight="35">
                        <Label text="U"/>
                    </StackPane>
                </HBox>
                <Button styleClass="btn-action-delete" onAction="#handleLogout" prefWidth="40" prefHeight="40">
                    <graphic><Label text="⬅" style="-fx-text-fill: #ef4444;"/></graphic>
                    <tooltip><Tooltip text="Déconnexion"/></tooltip>
                </Button>
            </HBox>
        </HBox>
    </top>

    <!-- ════════════════════════════════════════
         MAIN CONTENT AREA
    ════════════════════════════════════════ -->
    <center>
        <VBox spacing="0" style="-fx-background-color: transparent;">
            <!-- Content Header -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 30 40 10 40;">
                <VBox spacing="5">
                    <Label fx:id="topbarTitle" text="Dashboard" styleClass="page-title" style="-fx-font-size: 28px;"/>
                    <Label fx:id="topbarSubtitle" text="Bienvenue sur votre espace AIVA" styleClass="card-subtitle" style="-fx-font-size: 14px;"/>
                </VBox>
            </HBox>

            <!-- Dynamic Content Area -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-padding: 10 40 40 40;"/>
        </VBox>
    </center>

</BorderPane>
