<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox alignment="TOP_CENTER" spacing="30" style="-fx-background-color: transparent; -fx-padding: 40;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <VBox spacing="10">
        <Label text="Tableau de Bord FrontOffice" styleClass="page-title" style="-fx-font-size: 32px;"/>
        <Label text="Bienvenue sur votre assistant énergétique intelligent AIVA." styleClass="card-subtitle" style="-fx-font-size: 16px;"/>
    </VBox>

    <HBox spacing="20" alignment="CENTER_LEFT">
        <!-- Weather Widget -->
        <fx:include source="WeatherWidget.fxml"/>
        
        <!-- Quick Stats placeholder -->
        <VBox styleClass="glass-card" prefWidth="300" spacing="10">
            <Label text="Résumé Rapide" styleClass="card-title"/>
            <Label text="Tout fonctionne normalement." styleClass="card-subtitle"/>
            <ProgressBar progress="0.45" prefWidth="250" style="-fx-accent: #34d399;"/>
        </VBox>
    </HBox>
</VBox>
