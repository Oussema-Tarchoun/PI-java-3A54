<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.DepenseController"
      spacing="16"
      style="-fx-background-color:transparent;">
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="Toutes les depenses"
                   style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#ffffff;"/>
            <Label text="Liste des depenses par categorie"
                   style="-fx-font-size:13px; -fx-text-fill:#64748b;"/>
        </VBox>
        <Button text="+ Nouvelle depense" onAction="#ouvrirFormulaire"
                prefHeight="44"
                style="-fx-background-color:#00d4ff; -fx-text-fill:#0a0e1a;
                       -fx-font-weight:bold; -fx-background-radius:10px;
                       -fx-padding:10 24 10 24; -fx-cursor:hand; -fx-font-size:14px;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color:#161b2e; -fx-background-radius:12px;
                 -fx-padding:14px; -fx-border-color:#2a3142;
                 -fx-border-radius:12px; -fx-border-width:1px;">
        <TextField fx:id="montantMinField" promptText="Montant min"
                   prefWidth="140" prefHeight="42"
                   style="-fx-background-color:#111827; -fx-text-fill:#ffffff;
                          -fx-background-radius:8px; -fx-border-color:#2a3142;
                          -fx-border-radius:8px; -fx-border-width:1px;
                          -fx-padding:10 12 10 12; -fx-prompt-text-fill:#4a5568; -fx-font-size:14px;"/>
        <TextField fx:id="montantMaxField" promptText="Montant max"
                   prefWidth="140" prefHeight="42"
                   style="-fx-background-color:#111827; -fx-text-fill:#ffffff;
                          -fx-background-radius:8px; -fx-border-color:#2a3142;
                          -fx-border-radius:8px; -fx-border-width:1px;
                          -fx-padding:10 12 10 12; -fx-prompt-text-fill:#4a5568; -fx-font-size:14px;"/>
        <Button text="Filtrer" onAction="#filtrer" prefHeight="42"
                style="-fx-background-color:#00d4ff; -fx-text-fill:#0a0e1a;
                       -fx-font-weight:bold; -fx-background-radius:8px;
                       -fx-padding:10 18 10 18; -fx-cursor:hand; -fx-font-size:14px;"/>
        <Button text="Reinitialiser" onAction="#charger" prefHeight="42"
                style="-fx-background-color:#1e2538; -fx-text-fill:#94a3b8;
                       -fx-background-radius:8px; -fx-padding:10 18 10 18;
                       -fx-border-color:#2a3142; -fx-border-width:1px;
                       -fx-border-radius:8px; -fx-cursor:hand; -fx-font-size:14px;"/>
        <Button text="Date" onAction="#trierDate" prefHeight="42"
                style="-fx-background-color:#1e2538; -fx-text-fill:#94a3b8;
                       -fx-background-radius:8px; -fx-padding:10 18 10 18;
                       -fx-border-color:#2a3142; -fx-border-width:1px;
                       -fx-border-radius:8px; -fx-cursor:hand; -fx-font-size:14px;"/>
        <Button text="Montant" onAction="#trierMontant" prefHeight="42"
                style="-fx-background-color:#1e2538; -fx-text-fill:#94a3b8;
                       -fx-background-radius:8px; -fx-padding:10 18 10 18;
                       -fx-border-color:#2a3142; -fx-border-width:1px;
                       -fx-border-radius:8px; -fx-cursor:hand; -fx-font-size:14px;"/>
    </HBox>

    <VBox fx:id="formPane" spacing="14" managed="false" visible="false"
          style="-fx-background-color:#161b2e; -fx-background-radius:12px; -fx-padding:20px;
                 -fx-border-color:#00d4ff; -fx-border-radius:12px; -fx-border-width:1px;">
        <Label text="Nouvelle depense"
               style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#ffffff;"/>
        <HBox spacing="14">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Description" style="-fx-font-size:13px; -fx-text-fill:#94a3b8;"/>
                <TextField fx:id="descField" promptText="Ex: Courses supermarche"
                           prefHeight="42"
                           style="-fx-background-color:#111827; -fx-text-fill:#ffffff;
                                  -fx-background-radius:8px; -fx-border-color:#2a3142;
                                  -fx-border-radius:8px; -fx-border-width:1px;
                                  -fx-padding:10 12 10 12; -fx-prompt-text-fill:#4a5568; -fx-font-size:14px;"/>
            </VBox>
            <VBox spacing="6" prefWidth="160">
                <Label text="Montant (TND)" style="-fx-font-size:13px; -fx-text-fill:#94a3b8;"/>
                <TextField fx:id="montantField" promptText="Ex: 85.50"
                           prefHeight="42"
                           style="-fx-background-color:#111827; -fx-text-fill:#ffffff;
                                  -fx-background-radius:8px; -fx-border-color:#2a3142;
                                  -fx-border-radius:8px; -fx-border-width:1px;
                                  -fx-padding:10 12 10 12; -fx-prompt-text-fill:#4a5568; -fx-font-size:14px;"/>
            </VBox>
            <VBox spacing="6" prefWidth="185">
                <Label text="Date" style="-fx-font-size:13px; -fx-text-fill:#94a3b8;"/>
                <DatePicker fx:id="datePicker" prefWidth="185" prefHeight="42"
                            style="-fx-background-color:#111827; -fx-font-size:14px;
                                   -fx-background-radius:8px; -fx-border-color:#2a3142;
                                   -fx-border-radius:8px; -fx-border-width:1px;"/>
            </VBox>
            <VBox spacing="6" prefWidth="160">
                <Label text="Statut" style="-fx-font-size:13px; -fx-text-fill:#94a3b8;"/>
                <TextField fx:id="statutField" promptText="Ex: Validee"
                           prefHeight="42"
                           style="-fx-background-color:#111827; -fx-text-fill:#ffffff;
                                  -fx-background-radius:8px; -fx-border-color:#2a3142;
                                  -fx-border-radius:8px; -fx-border-width:1px;
                                  -fx-padding:10 12 10 12; -fx-prompt-text-fill:#4a5568; -fx-font-size:14px;"/>
            </VBox>
            <VBox spacing="6" prefWidth="210">
                <Label text="Categorie" style="-fx-font-size:13px; -fx-text-fill:#94a3b8;"/>
                <ComboBox fx:id="catCombo" promptText="Choisir..."
                          prefWidth="210" prefHeight="42"
                          style="-fx-background-color:#111827; -fx-font-size:14px;
                                 -fx-background-radius:8px; -fx-border-color:#2a3142;
                                 -fx-border-radius:8px; -fx-border-width:1px;"/>
            </VBox>
        </HBox>
        <Label fx:id="msgLabel" style="-fx-font-size:13px;"/>
        <HBox fx:id="btnAjouterBox" spacing="10">
            <Button text="Enregistrer" onAction="#ajouter" prefHeight="42"
                    style="-fx-background-color:#00d4ff; -fx-text-fill:#0a0e1a;
                           -fx-font-weight:bold; -fx-background-radius:8px;
                           -fx-padding:10 28 10 28; -fx-cursor:hand; -fx-font-size:14px;"/>
            <Button text="Annuler" onAction="#annuler" prefHeight="42"
                    style="-fx-background-color:#1e2538; -fx-text-fill:#94a3b8;
                           -fx-background-radius:8px; -fx-padding:10 28 10 28;
                           -fx-border-color:#2a3142; -fx-border-width:1px;
                           -fx-border-radius:8px; -fx-cursor:hand; -fx-font-size:14px;"/>
        </HBox>
        <HBox fx:id="btnModifierBox" spacing="10" managed="false" visible="false">
            <Button text="Modifier" onAction="#modifier" prefHeight="42"
                    style="-fx-background-color:#f59e0b; -fx-text-fill:#0a0e1a;
                           -fx-font-weight:bold; -fx-background-radius:8px;
                           -fx-padding:10 28 10 28; -fx-cursor:hand; -fx-font-size:14px;"/>
            <Button text="Annuler" onAction="#annuler" prefHeight="42"
                    style="-fx-background-color:#1e2538; -fx-text-fill:#94a3b8;
                           -fx-background-radius:8px; -fx-padding:10 28 10 28;
                           -fx-border-color:#2a3142; -fx-border-width:1px;
                           -fx-border-radius:8px; -fx-cursor:hand; -fx-font-size:14px;"/>
        </HBox>
    </VBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                style="-fx-background:transparent; -fx-background-color:transparent; -fx-border-width:0;">
        <FlowPane fx:id="cardsPane" hgap="16" vgap="16"
                  style="-fx-background-color:transparent; -fx-padding:4px;"/>
    </ScrollPane>
</VBox>