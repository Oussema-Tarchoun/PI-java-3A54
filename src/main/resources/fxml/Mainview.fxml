<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.MainController"
            stylesheets="@/Styles/aiva-theme.css"
            style="-fx-background-color:#0a0e1a;">
    <left>
        <VBox style="-fx-background-color:#111827;
                     -fx-min-width:220; -fx-max-width:220;
                     -fx-padding:20 0 20 0; -fx-spacing:2;">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding:0 20 28 20;">
                <StackPane minWidth="36" minHeight="36" maxWidth="36" maxHeight="36"
                           style="-fx-background-color:rgba(0,212,255,0.15);
                                  -fx-background-radius:10px;">
                    <Label text="▲" style="-fx-text-fill:#00d4ff; -fx-font-size:16px;"/>
                </StackPane>
                <Label text="AIVA"
                       style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#ffffff;"/>
            </HBox>
            <Separator style="-fx-background-color:#2a3142; -fx-opacity:0.5;"/>
            <VBox spacing="4" VBox.vgrow="ALWAYS" style="-fx-padding:16 8 0 8;">
                <Label text="FINANCE"
                       style="-fx-font-size:10px; -fx-text-fill:#4a5568;
                              -fx-padding:0 8 6 8; -fx-font-weight:bold;"/>
                <Button fx:id="btnDepenses"
                        text="Depenses"
                        onAction="#openDepenses"
                        maxWidth="Infinity"
                        style="-fx-background-color:rgba(0,212,255,0.1);
                               -fx-text-fill:#00d4ff;
                               -fx-font-size:14px; -fx-font-weight:bold;
                               -fx-padding:12 16 12 16;
                               -fx-alignment:CENTER_LEFT;
                               -fx-cursor:hand;
                               -fx-background-radius:8px;
                               -fx-border-color:rgba(0,212,255,0.2);
                               -fx-border-radius:8px; -fx-border-width:1px;"/>
                <Button fx:id="btnCategories"
                        text="Categories"
                        onAction="#openCategories"
                        maxWidth="Infinity"
                        style="-fx-background-color:transparent;
                               -fx-text-fill:#94a3b8;
                               -fx-font-size:14px;
                               -fx-padding:12 16 12 16;
                               -fx-alignment:CENTER_LEFT;
                               -fx-cursor:hand;
                               -fx-background-radius:8px;"/>
            </VBox>
            <VBox spacing="8" style="-fx-padding:16 16 0 16;">
                <Separator style="-fx-background-color:#2a3142;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"
                               style="-fx-background-color:rgba(0,212,255,0.1);
                                      -fx-background-radius:16px;">
                        <Label text="U" style="-fx-text-fill:#00d4ff; -fx-font-size:13px; -fx-font-weight:bold;"/>
                    </StackPane>
                    <Label fx:id="labelUser" text="Utilisateur"
                           style="-fx-font-size:13px; -fx-text-fill:#94a3b8;"/>
                </HBox>
            </VBox>
        </VBox>
    </left>
    <center>
        <VBox style="-fx-background-color:#0a0e1a;">
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color:#0d1117;
                         -fx-padding:16 28 16 28;
                         -fx-border-color:#2a3142;
                         -fx-border-width:0 0 1 0;">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label fx:id="topbarTitle" text="Depenses"
                           style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#ffffff;"/>
                    <Label fx:id="topbarSubtitle" text="Gestion des depenses"
                           style="-fx-font-size:12px; -fx-text-fill:#64748b;"/>
                </VBox>
                <Label fx:id="topbarUser" text="Bonjour, Utilisateur"
                       style="-fx-font-size:13px; -fx-text-fill:#64748b;
                              -fx-background-color:#161b2e;
                              -fx-background-radius:8px;
                              -fx-padding:8 16 8 16;
                              -fx-border-color:#2a3142;
                              -fx-border-radius:8px; -fx-border-width:1px;"/>
            </HBox>
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS"
                       style="-fx-padding:24 28 24 28; -fx-background-color:#0a0e1a;"/>
        </VBox>
    </center>
</BorderPane>