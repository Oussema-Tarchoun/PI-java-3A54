<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="720.0" prefWidth="1080.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.FrontController"
            stylesheets="@styles.css">

    <!-- Left Sidebar -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
          spacing="0" styleClass="sidebar">
        <!-- Logo Area -->
        <VBox alignment="CENTER" styleClass="logo-box" prefHeight="80">
            <Label text="AIVA" styleClass="logo-text"/>
            <Label text="User" styleClass="logo-name"/>
        </VBox>
        <Pane styleClass="logo-separator"/>

        <!-- Nav Buttons -->
        <Button text="&#127968;  Accueil" maxWidth="Infinity" styleClass="nav-item active"/>
        
        <Pane VBox.vgrow="ALWAYS"/>
        
        <Button text="&#128274;  Déconnexion" maxWidth="Infinity" styleClass="nav-item"
                onAction="#handleLogout" id="btnLogout"/>
    </VBox>

    <!-- Main Content -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="250" AnchorPane.rightAnchor="0"
          styleClass="main-window">

        <!-- Top Bar -->
        <HBox alignment="CENTER_LEFT" styleClass="top-navbar">
            <Label text="Espace Utilisateur" styleClass="page-title"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label text="Bienvenue" style="-fx-text-fill: rgba(245,245,244,0.6);"/>
        </HBox>

        <VBox alignment="CENTER" VBox.vgrow="ALWAYS" spacing="20">
            <Label fx:id="lblWelcome" styleClass="page-title" style="-fx-font-size: 36px;"/>
            <Label text="Ceci est l'interface front-end pour les utilisateurs classiques." styleClass="card-subtitle"/>
            <Label text="Découvrez nos fonctionnalités bientôt disponibles !" styleClass="card-subtitle"/>
        </VBox>

    </VBox>
</AnchorPane>
