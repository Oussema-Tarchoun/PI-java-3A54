<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.ObjectifFrontController"
      spacing="24"
      style="-fx-background-color: transparent; -fx-padding: 0;">

    <!-- ── STAT CARDS ──────────────────────────────────── -->
    <HBox spacing="16" alignment="CENTER_LEFT">
        <VBox styleClass="user-stat-card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="user-icon-box user-icon-cyan">
                    <Label text="🎯" style="-fx-font-size:15px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Total objectifs" styleClass="user-stat-label"/>
                    <Label fx:id="statTotalLabel" text="0" styleClass="user-stat-value"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="user-stat-card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="user-icon-box user-icon-orange">
                    <Label text="⏳" style="-fx-font-size:15px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="En cours" styleClass="user-stat-label"/>
                    <Label fx:id="statEnCoursLabel" text="0" styleClass="user-stat-value"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="user-stat-card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="user-icon-box user-icon-green">
                    <Label text="✓" style="-fx-font-size:15px; -fx-text-fill:#10b981;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Terminés" styleClass="user-stat-label"/>
                    <Label fx:id="statTerminesLabel" text="0" styleClass="user-stat-value"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
            <Button text="＋  Nouvel objectif"
                    styleClass="user-btn-primary"
                    onAction="#ouvrirFormulaire"/>
        </VBox>
    </HBox>

    <!-- ── ADD / EDIT FORM ─────────────────────────────── -->
    <VBox fx:id="formPane" styleClass="user-form-card"
          spacing="16" visible="false" managed="false">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <StackPane styleClass="user-icon-box user-icon-cyan">
                <Label text="🎯" style="-fx-font-size:13px;"/>
            </StackPane>
            <Label text="Nouvel objectif" styleClass="user-form-title"/>
        </HBox>
        <GridPane hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            </columnConstraints>
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="5">
                <Label text="Description" styleClass="user-field-label"/>
                <TextField fx:id="descField" promptText="Décrivez votre objectif…" styleClass="user-field"/>
            </VBox>
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="5">
                <Label text="Type" styleClass="user-field-label"/>
                <TextField fx:id="typeField" promptText="Perte de poids, Endurance…" styleClass="user-field"/>
            </VBox>
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="5">
                <Label text="Valeur cible" styleClass="user-field-label"/>
                <TextField fx:id="valeurCibleField" promptText="5000" styleClass="user-field"/>
            </VBox>
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="5">
                <Label text="Statut" styleClass="user-field-label"/>
                <TextField fx:id="statutField" promptText="En cours, Terminé…" styleClass="user-field"/>
            </VBox>
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" spacing="5">
                <Label text="Date de début" styleClass="user-field-label"/>
                <DatePicker fx:id="dateDebutPicker" styleClass="user-field" maxWidth="Infinity"/>
            </VBox>
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="2" spacing="5">
                <Label text="Date de fin" styleClass="user-field-label"/>
                <DatePicker fx:id="dateFinPicker" styleClass="user-field" maxWidth="Infinity"/>
            </VBox>
        </GridPane>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="msgLabel" text="" HBox.hgrow="ALWAYS" style="-fx-font-size:12px;"/>
            <HBox fx:id="btnAjouterBox" spacing="8">
                <Button text="✓  Enregistrer" styleClass="user-btn-primary" onAction="#ajouter"/>
                <Button text="Annuler"         styleClass="user-btn-ghost"   onAction="#annuler"/>
            </HBox>
            <HBox fx:id="btnModifierBox" spacing="8" visible="false" managed="false">
                <Button text="✓  Modifier" styleClass="user-btn-primary" onAction="#modifier"/>
                <Button text="Annuler"     styleClass="user-btn-ghost"   onAction="#annuler"/>
            </HBox>
        </HBox>
    </VBox>

    <!-- ── OBJECTIVE CARDS (populated by controller) ───── -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Mes objectifs" styleClass="user-section-title" HBox.hgrow="ALWAYS"/>
        <Button text="↻ Actualiser" styleClass="user-btn-ghost" onAction="#charger"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="cardGrid"
                  hgap="16" vgap="16"
                  prefWrapLength="880"
                  style="-fx-background-color: transparent; -fx-padding: 2 0 8 0;"/>
    </ScrollPane>

    <Label fx:id="emptyLabel"
           text="Aucun objectif enregistré. Cliquez sur « Nouvel objectif » pour commencer !"
           styleClass="user-empty-label"
           wrapText="true"
           visible="false" managed="false"/>

</VBox>
