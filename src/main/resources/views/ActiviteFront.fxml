<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.ActiviteFrontController"
      spacing="24"
      style="-fx-background-color: transparent; -fx-padding: 0;">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ║  STAT CARDS + ACTION BUTTONS                        ║ -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <HBox spacing="16" alignment="CENTER_LEFT">
        <VBox styleClass="user-stat-card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="user-icon-box user-icon-cyan">
                    <Label text="⚡" style="-fx-font-size:15px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Total activités" styleClass="user-stat-label"/>
                    <Label fx:id="statTotalLabel" text="0" styleClass="user-stat-value"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="user-stat-card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="user-icon-box user-icon-pink">
                    <Label text="🔥" style="-fx-font-size:15px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Calories brûlées" styleClass="user-stat-label"/>
                    <Label fx:id="statCaloriesLabel" text="0 kcal" styleClass="user-stat-value"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="user-stat-card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="user-icon-box user-icon-purple">
                    <Label text="⏱" style="-fx-font-size:15px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Durée totale" styleClass="user-stat-label"/>
                    <Label fx:id="statDureeLabel" text="0 min" styleClass="user-stat-value"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" spacing="8">
            <Button text="＋  Ajouter une activité"
                    styleClass="user-btn-primary"
                    onAction="#ouvrirFormulaire"/>
        </VBox>
    </HBox>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ║  WEATHER WIDGET                                     ║ -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <VBox spacing="10" styleClass="user-stat-card">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="🌤 Météo actuelle :" styleClass="user-stat-label"/>
            <Label fx:id="weatherLabel" text="Chargement..." styleClass="user-stat-value"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="📊 Recommandation :" styleClass="user-stat-label"/>
            <Label fx:id="weatherAdviceLabel" text="..." />
        </HBox>
    </VBox>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ║  ADD / EDIT FORM                                     ║ -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <VBox fx:id="formPane" styleClass="user-form-card"
          spacing="16" visible="false" managed="false">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <StackPane styleClass="user-icon-box user-icon-cyan">
                <Label text="＋" style="-fx-font-size:13px; -fx-text-fill:#00d4ff;"/>
            </StackPane>
            <Label text="Nouvelle activité" styleClass="user-form-title"/>
        </HBox>
        <GridPane hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="33"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="33"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="34"/>
            </columnConstraints>
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="5">
                <Label text="Type d'activité" styleClass="user-field-label"/>
                <TextField fx:id="typeField" promptText="Course, Natation…" styleClass="user-field"/>
            </VBox>
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="5">
                <Label text="Durée (min)" styleClass="user-field-label"/>
                <TextField fx:id="dureeField" promptText="45" styleClass="user-field"/>
            </VBox>
            <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="5">
                <Label text="Calories" styleClass="user-field-label"/>
                <TextField fx:id="caloriesField" promptText="320" styleClass="user-field"/>
            </VBox>
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="5">
                <Label text="Intensité" styleClass="user-field-label"/>
                <TextField fx:id="intensiteField" promptText="Modérée, Élevée…" styleClass="user-field"/>
            </VBox>
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="5">
                <Label text="Date" styleClass="user-field-label"/>
                <DatePicker fx:id="datePicker" styleClass="user-field" maxWidth="Infinity"/>
            </VBox>
            <VBox GridPane.columnIndex="2" GridPane.rowIndex="1" spacing="5">
                <Label text="Objectif lié" styleClass="user-field-label"/>
                <ComboBox fx:id="objectifCombo" styleClass="user-field" maxWidth="Infinity"/>
            </VBox>
        </GridPane>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="msgLabel" text="" HBox.hgrow="ALWAYS" style="-fx-font-size:12px;"/>
            <HBox fx:id="btnAjouterBox" spacing="8">
                <Button text="✓  Enregistrer" styleClass="user-btn-primary" onAction="#ajouter"/>
                <Button text="Annuler"         styleClass="user-btn-ghost"   onAction="#annuler"/>
            </HBox>
            <HBox fx:id="btnModifierBox" spacing="8" visible="false" managed="false">
                <Button text="✓  Modifier" styleClass="user-btn-primary" onAction="#modifier"/>
                <Button text="Annuler"     styleClass="user-btn-ghost"   onAction="#annuler"/>
            </HBox>
        </HBox>
    </VBox>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ║  SEARCH AND FILTER BAR                               ║ -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Mes activités" styleClass="user-section-title" HBox.hgrow="ALWAYS"/>

        <!-- 🔍 Champ de recherche -->
        <TextField fx:id="searchField" promptText="🔍 Rechercher..."
                   styleClass="search-field"
                   prefWidth="180"
                   style="-fx-background-color:#1e2538; -fx-text-fill:white; -fx-background-radius:20px; -fx-padding:8 16 8 16;
                          -fx-border-color:#2a3142; -fx-border-radius:20px; -fx-border-width:1px;"/>

        <!-- 🏷️ Filtre par type -->
        <ComboBox fx:id="filterTypeCombo" styleClass="filter-combo"
                  prefWidth="120"
                  style="-fx-background-color:#1e2538; -fx-text-fill:white; -fx-background-radius:8px;
                         -fx-border-color:#2a3142; -fx-border-radius:8px; -fx-border-width:1px;
                         -fx-padding:6 12 6 12;"/>

        <!-- 🏷️ Filtre par intensité -->
        <ComboBox fx:id="filterIntensiteCombo" styleClass="filter-combo"
                  prefWidth="120"
                  style="-fx-background-color:#1e2538; -fx-text-fill:white; -fx-background-radius:8px;
                         -fx-border-color:#2a3142; -fx-border-radius:8px; -fx-border-width:1px;
                         -fx-padding:6 12 6 12;"/>

        <!-- 📅 Filtre par période -->
        <DatePicker fx:id="startDatePicker" promptText="Début"
                    styleClass="filter-date"
                    prefWidth="120"
                    style="-fx-background-color:#1e2538; -fx-text-fill:white; -fx-background-radius:8px;
                           -fx-border-color:#2a3142; -fx-border-radius:8px; -fx-border-width:1px;"/>
        <Label text="→" style="-fx-text-fill:#94a3b8; -fx-font-size:14px;"/>
        <DatePicker fx:id="endDatePicker" promptText="Fin"
                    styleClass="filter-date"
                    prefWidth="120"
                    style="-fx-background-color:#1e2538; -fx-text-fill:white; -fx-background-radius:8px;
                           -fx-border-color:#2a3142; -fx-border-radius:8px; -fx-border-width:1px;"/>

        <!-- 📊 Tri -->
        <ComboBox fx:id="sortCombo" styleClass="filter-combo"
                  prefWidth="170"
                  style="-fx-background-color:#1e2538; -fx-text-fill:white; -fx-background-radius:8px;
                         -fx-border-color:#2a3142; -fx-border-radius:8px; -fx-border-width:1px;
                         -fx-padding:6 12 6 12;"/>

        <Button text="🏋️ Coach IA" onAction="#genererCoaching"
                prefHeight="40"
                style="-fx-background-color:#1e2538; -fx-text-fill:#a855f7;
                       -fx-font-weight:bold; -fx-background-radius:10px;
                       -fx-padding:10 20 10 20; -fx-cursor:hand; -fx-font-size:13px;
                       -fx-border-color:#a855f7; -fx-border-width:1px;
                       -fx-border-radius:10px;"/>
        <Button text="📧 Rapport Email" onAction="#envoyerRapportMail"
                prefHeight="40"
                style="-fx-background-color:#1e2538; -fx-text-fill:#22c55e;
                       -fx-font-weight:bold; -fx-background-radius:10px;
                       -fx-padding:10 20 10 20; -fx-cursor:hand; -fx-font-size:13px;
                       -fx-border-color:#22c55e; -fx-border-width:1px;
                       -fx-border-radius:10px;"/>
        <Button text="⬇ Exporter PDF" onAction="#exporterPDF"
                prefHeight="40"
                style="-fx-background-color:rgba(239,68,68,0.15);
                       -fx-text-fill:#ef4444;
                       -fx-font-weight:bold; -fx-background-radius:10px;
                       -fx-padding:10 20 10 20; -fx-cursor:hand; -fx-font-size:13px;
                       -fx-border-color:rgba(239,68,68,0.3);
                       -fx-border-radius:10px; -fx-border-width:1px;"/>
        <Button text="↻ Actualiser" styleClass="user-btn-ghost" onAction="#charger"/>
    </HBox>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ║  CARD GRID                                          ║ -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="cardGrid"
                  hgap="16" vgap="16"
                  prefWrapLength="880"
                  style="-fx-background-color: transparent; -fx-padding: 2 0 8 0;"/>
    </ScrollPane>

    <!-- Empty state -->
    <Label fx:id="emptyLabel"
           text="Aucune activité enregistrée. Cliquez sur « Ajouter » pour commencer !"
           styleClass="user-empty-label"
           wrapText="true"
           visible="false" managed="false"/>

</VBox>