<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<VBox prefWidth="400" spacing="20"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.TwoFactorSetupController"
      stylesheets="@styles.css"
      styleClass="dialog-pane">
    
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <VBox spacing="8" alignment="CENTER">
        <Label text="Configuration 2FA" styleClass="card-title" style="-fx-font-size: 20px;"/>
        <Label text="Scannez ce QR code avec Google Authenticator ou Authy." 
               styleClass="card-subtitle" wrapText="true" textAlignment="CENTER"/>
    </VBox>

    <HBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10;">
        <ImageView fx:id="ivQrCode" fitWidth="200" fitHeight="200" preserveRatio="true"/>
    </HBox>

    <VBox spacing="6">
        <Label text="Code de confirmation" styleClass="form-label"/>
        <TextField fx:id="tfConfirmCode" promptText="000000" styleClass="form-input" alignment="CENTER"/>
    </VBox>

    <Label fx:id="lblError" text="" styleClass="error-label" managed="false" visible="false" wrapText="true"/>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="Activer 2FA" onAction="#handleEnable" styleClass="btn-primary"/>
    </HBox>

</VBox>
