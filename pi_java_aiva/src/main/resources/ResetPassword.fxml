<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefWidth="1080.0" prefHeight="680.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.ResetPasswordController"
            stylesheets="@styles.css">

    <!-- Left decorative panel (Consistent with Login) -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" prefWidth="480"
          styleClass="auth-left-panel" alignment="CENTER" spacing="24">
        <Label text="&#9670; AIVA" styleClass="auth-brand-logo"/>
        <Label text="Admin Portal" styleClass="auth-brand-sub"/>
        <Label text="Gérez vos utilisateurs,&#10;vos cours et bien plus." styleClass="auth-brand-desc"
               wrapText="true" textAlignment="CENTER"/>
        <Label text="&#128272;" styleClass="auth-brand-icon"/>
    </VBox>

    <!-- Right form panel -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="480" AnchorPane.rightAnchor="0"
          styleClass="auth-right-panel" alignment="CENTER" spacing="0">

        <VBox maxWidth="380" spacing="28">

            <VBox spacing="6">
                <Label text="Réinitialisation" styleClass="auth-title"/>
                <Label fx:id="lblSubtitle" text="Récupérez l'accès à votre compte administrateur." styleClass="auth-subtitle" wrapText="true"/>
            </VBox>

            <!-- STEP 1: Enter Email -->
            <VBox fx:id="step1Email" spacing="20">
                <VBox spacing="6">
                    <Label text="Adresse Email" styleClass="form-label"/>
                    <TextField fx:id="tfEmail" promptText="votre@email.com" styleClass="form-field"/>
                </VBox>
                <Button text="Recevoir le code &#8594;" styleClass="btn-primary" maxWidth="Infinity" prefHeight="44" onAction="#handleSendCode"/>
            </VBox>

            <!-- STEP 2: Enter Code and New Password (Hidden by default) -->
            <VBox fx:id="step2Reset" spacing="16" visible="false" managed="false">
                <VBox spacing="6">
                    <Label text="Code de validation" styleClass="form-label"/>
                    <TextField fx:id="tfToken" promptText="000000" styleClass="form-field"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Nouveau mot de passe" styleClass="form-label"/>
                    <PasswordField fx:id="pfNewPassword" promptText="••••••••" styleClass="form-field"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Confirmer le mot de passe" styleClass="form-label"/>
                    <PasswordField fx:id="pfConfirmPassword" promptText="••••••••" styleClass="form-field"/>
                </VBox>
                <Button text="Changer le mot de passe" styleClass="btn-primary" maxWidth="Infinity" prefHeight="44" onAction="#handleReset"/>
            </VBox>

            <!-- Feedback labels -->
            <VBox spacing="4">
                <Label fx:id="lblError" text="" styleClass="error-label" wrapText="true" managed="false" visible="false"/>
                <Label fx:id="lblSuccess" text="" style=" -fx-text-fill: #22c55e; -fx-font-size: 12px;" wrapText="true" managed="false" visible="false"/>
            </VBox>

            <!-- Back to login -->
            <HBox alignment="CENTER" spacing="8">
                <Button text="&#8592; Retour à la connexion" styleClass="btn-link" onAction="#goToLogin"/>
            </HBox>

        </VBox>
    </VBox>
</AnchorPane>
