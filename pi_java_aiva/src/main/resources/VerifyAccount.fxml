<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="680.0" prefWidth="1080.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.VerifyAccountController">

    <!-- Left decorative panel (consistent with Login/Register) -->
    <VBox alignment="CENTER" prefWidth="480" spacing="24" styleClass="auth-left-panel" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">
        <Label styleClass="auth-brand-logo" text="◆ AIVA" />
        <Label styleClass="auth-brand-sub" text="Admin Portal" />
        <Label styleClass="auth-brand-desc" text="Sécurisez votre compte&#10;en vérifiant votre email." textAlignment="CENTER" wrapText="true" />
        <Label styleClass="auth-brand-icon" text="📧" />
    </VBox>

    <!-- Right verification form -->
    <VBox alignment="CENTER" spacing="0" styleClass="auth-right-panel" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="480" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <VBox maxWidth="380" spacing="32">

            <!-- Header -->
            <VBox spacing="8">
                <Label styleClass="auth-title" text="Vérification du compte" />
                <Label fx:id="lblInstruction" styleClass="auth-subtitle" text="Veuillez saisir le code à 6 chiffres envoyé à votre adresse email." wrapText="true" />
            </VBox>

            <!-- Form -->
            <VBox spacing="20">
                <VBox spacing="8">
                    <Label styleClass="form-label" text="Code de vérification *" />
                    <TextField fx:id="tfVerificationCode" alignment="CENTER" prefHeight="50" promptText="000000" style="-fx-font-size: 24px; -fx-letter-spacing: 12px; -fx-font-weight: bold;" styleClass="form-field" />
                </VBox>

                <!-- Error label -->
                <Label fx:id="lblError" managed="false" styleClass="error-label" text="" visible="false" wrapText="true" />

                <!-- Verify button -->
                <Button defaultButton="true" maxWidth="Infinity" onAction="#handleVerify" prefHeight="44" styleClass="btn-primary" text="Vérifier le compte →" />
                
                <HBox alignment="CENTER" spacing="10">
                     <Label styleClass="auth-subtitle" text="Vous n'avez pas reçu de code ?" />
                     <Button onAction="#handleResendCode" styleClass="btn-link" text="Renvoyer" />
                </HBox>
            </VBox>

            <!-- Back to login -->
            <HBox alignment="CENTER">
                <Button onAction="#goToLogin" styleClass="btn-link" text="Retour à la connexion" />
            </HBox>

        </VBox>
    </VBox>
</AnchorPane>
