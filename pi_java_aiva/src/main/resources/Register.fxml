<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefWidth="1080.0" prefHeight="680.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.RegisterController"
            stylesheets="@styles.css">

    <!-- Left decorative panel -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" prefWidth="480"
          styleClass="auth-left-panel" alignment="CENTER" spacing="24">
        <Label text="&#9670; AIVA" styleClass="auth-brand-logo"/>
        <Label text="Admin Portal" styleClass="auth-brand-sub"/>
        <Label text="Rejoignez la plateforme&#10;d'administration AIVA." styleClass="auth-brand-desc"
               wrapText="true" textAlignment="CENTER"/>
        <Label text="&#127919;" styleClass="auth-brand-icon"/>
    </VBox>

    <!-- Right register form -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="480" AnchorPane.rightAnchor="0"
          styleClass="auth-right-panel" alignment="CENTER" spacing="0">

        <VBox maxWidth="380" spacing="28">

            <!-- Header -->
            <VBox spacing="6">
                <Label text="Créer un compte" styleClass="auth-title"/>
                <Label text="Remplissez les champs pour vous inscrire." styleClass="auth-subtitle"/>
            </VBox>

            <!-- Form -->
            <VBox spacing="14">

                <HBox spacing="12">
                    <VBox HBox.hgrow="ALWAYS" spacing="6">
                        <Label text="Nom complet *" styleClass="form-label"/>
                        <TextField fx:id="tfName" promptText="Jean Dupont"
                                   styleClass="form-field" id="tfRegisterName"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Adresse Email *" styleClass="form-label"/>
                    <TextField fx:id="tfEmail" promptText="jean@exemple.com"
                               styleClass="form-field" id="tfRegisterEmail"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Rôle *" styleClass="form-label"/>
                    <ComboBox fx:id="cbRole" promptText="Choisir un rôle"
                              maxWidth="Infinity" styleClass="form-field" id="cbRegisterRole"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Mot de passe *" styleClass="form-label"/>
                    <PasswordField fx:id="pfPassword" promptText="••••••••"
                                  styleClass="form-field" id="pfRegisterPassword"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Confirmer le mot de passe *" styleClass="form-label"/>
                    <PasswordField fx:id="pfConfirm" promptText="••••••••"
                                  styleClass="form-field" id="pfRegisterConfirm"
                                  onAction="#handleRegister"/>
                </VBox>

                <!-- Error / success label -->
                <Label fx:id="lblError" text="" styleClass="error-label"
                       wrapText="true" managed="false" visible="false"/>

                <!-- Register button -->
                <Button text="S'inscrire &#8594;" styleClass="btn-primary"
                        maxWidth="Infinity" prefHeight="44"
                        onAction="#handleRegister" id="btnRegisterSubmit"
                        defaultButton="true"/>

            </VBox>

            <!-- Separator -->
            <HBox alignment="CENTER" spacing="12">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="ou" styleClass="auth-or-label"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Login link -->
            <HBox alignment="CENTER" spacing="8">
                <Label text="Déjà un compte ?" styleClass="auth-subtitle"/>
                <Button text="Se connecter" styleClass="btn-link"
                        onAction="#goToLogin" id="btnGoLogin"/>
            </HBox>

        </VBox>
    </VBox>
</AnchorPane>
