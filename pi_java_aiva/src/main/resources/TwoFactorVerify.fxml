<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefWidth="1080.0" prefHeight="680.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.TwoFactorVerifyController"
            stylesheets="@styles.css">

    <!-- Left decorative panel -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" prefWidth="480"
          styleClass="auth-left-panel" alignment="CENTER" spacing="24">
        <Label text="&#9670; AIVA" styleClass="auth-brand-logo"/>
        <Label text="Double Authentification" styleClass="auth-brand-sub"/>
        <Label text="Sécurisez votre compte avec un&#10;code de validation." styleClass="auth-brand-desc"
               wrapText="true" textAlignment="CENTER"/>
        <Label text="&#128273;" styleClass="auth-brand-icon"/>
    </VBox>

    <!-- Right form -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="480" AnchorPane.rightAnchor="0"
          styleClass="auth-right-panel" alignment="CENTER" spacing="0">

        <VBox maxWidth="380" spacing="28">

            <!-- Header -->
            <VBox spacing="6">
                <Label text="Vérification 2FA" styleClass="auth-title"/>
                <Label text="Entrez le code de 6 chiffres généré par votre application." styleClass="auth-subtitle" wrapText="true"/>
            </VBox>

            <!-- Form -->
            <VBox spacing="16">

                <VBox spacing="6">
                    <Label text="Code de validation" styleClass="form-label"/>
                    <TextField fx:id="tfCode" promptText="000000"
                               styleClass="form-field" id="tf2faCode"
                               onAction="#handleVerify"/>
                </VBox>

                <!-- Error label -->
                <Label fx:id="lblError" text="" styleClass="error-label"
                       wrapText="true" managed="false" visible="false"/>

                <!-- Verify button -->
                <Button text="Vérifier &#8594;" styleClass="btn-primary"
                        maxWidth="Infinity" prefHeight="44"
                        onAction="#handleVerify" id="btn2faVerify"
                        defaultButton="true"/>

                <Button text="Retour à la connexion" styleClass="btn-link"
                        maxWidth="Infinity" onAction="#handleBackToLogin"/>

            </VBox>

        </VBox>
    </VBox>
</AnchorPane>
