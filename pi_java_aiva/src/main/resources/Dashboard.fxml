<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="720.0" prefWidth="1080.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.DashboardController"
            stylesheets="@styles.css">

    <!-- Left Sidebar -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
          spacing="0" styleClass="sidebar">
        <!-- Logo Area -->
        <VBox alignment="CENTER" styleClass="logo-box" prefHeight="80">
            <Label text="AIVA" styleClass="logo-text"/>
            <Label text="Admin" styleClass="logo-name"/>
        </VBox>
        <Pane styleClass="logo-separator"/>

        <!-- Nav Buttons -->
        <Button text="&#127968;  Dashboard" maxWidth="Infinity" styleClass="nav-item active" id="btnDashNav"/>
        <Button text="&#128100;  User Management" maxWidth="Infinity" styleClass="nav-item"
                onAction="#openUserManagement" id="btnUsersNav"/>
        <Button text="&#128203;  Global Reports" maxWidth="Infinity" styleClass="nav-item"
                onAction="#openReportManagement" id="btnReportsNav"/>
        
        <Pane VBox.vgrow="ALWAYS"/>
        
        <Button text="&#128274;  Déconnexion" maxWidth="Infinity" styleClass="nav-item"
                onAction="#handleLogout" id="btnLogout"/>
    </VBox>

    <!-- Main Content -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="250" AnchorPane.rightAnchor="0"
          styleClass="main-window">

        <!-- Top Bar -->
        <HBox alignment="CENTER_LEFT" styleClass="top-navbar">
            <Label text="Administration Dashboard" styleClass="page-title"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label text="Bienvenue, Administrateur" style="-fx-text-fill: rgba(245,245,244,0.6);"/>
        </HBox>

        <!-- Stats Cards Row -->
        <HBox spacing="20" styleClass="stats-row">
            <VBox.margin>
                <Insets top="30" right="30" bottom="0" left="30"/>
            </VBox.margin>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <VBox styleClass="stat-icon-cyan">
                        <Label text="&#128100;" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                    </VBox>
                    <VBox>
                        <Label text="UTILISATEURS" styleClass="stat-label"/>
                        <Label fx:id="lblTotalUsers" text="—" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <VBox styleClass="stat-icon-info">
                        <Label text="&#9989;" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                    </VBox>
                    <VBox>
                        <Label text="VÉRIFIÉS" styleClass="stat-label"/>
                        <Label fx:id="lblVerifiedUsers" text="—" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <VBox styleClass="stat-icon-danger">
                        <Label text="&#128683;" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                    </VBox>
                    <VBox>
                        <Label text="BLOQUÉS" styleClass="stat-label"/>
                        <Label fx:id="lblBlockedUsers" text="—" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <VBox styleClass="stat-icon-warning">
                        <Label text="&#128274;" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                    </VBox>
                    <VBox>
                        <Label text="ADMINS" styleClass="stat-label"/>
                        <Label fx:id="lblAdminUsers" text="—" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <!-- Quick Access Section -->
        <Label text="Raccourcis de Gestion" styleClass="section-title">
            <VBox.margin><Insets top="40" left="30" bottom="15" right="30"/></VBox.margin>
        </Label>
        
        <HBox spacing="20">
            <VBox.margin><Insets left="30" right="30"/></VBox.margin>
            
            <VBox styleClass="glass-card" onMouseClicked="#openUserManagement" HBox.hgrow="ALWAYS" alignment="CENTER" prefHeight="200">
                <Label text="&#128100;" style="-fx-font-size: 40px; -fx-text-fill: #34d399;"/>
                <Label text="Comptes Utilisateurs" styleClass="card-title"/>
                <Label text="Gérer les accès, modifier les profils et visualiser les statistiques." styleClass="card-subtitle" alignment="CENTER" textAlignment="CENTER" wrapText="true"/>
                <Button text="Gérer les Utilisateurs →" styleClass="btn-primary" onAction="#openUserManagement">
                    <VBox.margin><Insets top="15"/></VBox.margin>
                </Button>
            </VBox>

            <VBox styleClass="glass-card" onMouseClicked="#openReportManagement" HBox.hgrow="ALWAYS" alignment="CENTER" prefHeight="200">
                <Label text="&#128203;" style="-fx-font-size: 40px; -fx-text-fill: #d4a574;"/>
                <Label text="Rapports d'Activité" styleClass="card-title"/>
                <Label text="Consulter l'historique complet, filtrer par auteur et exporter." styleClass="card-subtitle" alignment="CENTER" textAlignment="CENTER" wrapText="true"/>
                <Button text="Ouvrir les Rapports →" styleClass="btn-secondary" onAction="#openReportManagement">
                    <VBox.margin><Insets top="15"/></VBox.margin>
                </Button>
            </VBox>
        </HBox>

    </VBox>
</AnchorPane>
